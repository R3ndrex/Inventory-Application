<!DOCTYPE html>
<html lang="en">
    <%-include("../partials/head",{title:"Game Page"})%>
    <body>
        <h1>Game Page</h1>
        <h2><%=locals?.name%></h2>
        <img src="<%=locals?.imagesrc%>" alt="<%=locals?.name%> image" />
        
        <%if(locals?.developers){%>
            <div class="developers-list-gamepage">
                <p>Developers:</p>
                <ul>
                    <%locals?.developers.forEach((developer)=>{%>
                        <li><%=developer%></li>
                    <%})%>
                </ul>
            </div>
            <%}%>
        <%if(locals?.categories){%>
            <div class="categories-list-gamepage">
                <p>Categories:</p> 
                <ul>
                    <%locals?.categories.forEach((category)=>{%>
                        <li><%=category%></li>
                    <%})%>
                </ul>
            </div>
        
        <%}%>
    </body>
</html>
